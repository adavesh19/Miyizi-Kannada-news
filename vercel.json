{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/public_html/assets/:path*"
    },
    {
      "source": "/ads.txt",
      "destination": "/public_html/ads.txt"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/robots.php"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.php"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/rss.php"
    },
    {
      "source": "/rss/:category.xml",
      "destination": "/api/rss.php?category=:category"
    },
    {
      "source": "/feed/:category.xml",
      "destination": "/api/rss.php?category=:category"
    },
    {
      "source": "/category/:category/feed.xml",
      "destination": "/api/rss.php?category=:category"
    },
    {
      "source": "/api/categories.php",
      "destination": "/api/api/categories.php"
    },
    {
      "source": "/api/latest.php",
      "destination": "/api/api/latest.php"
    },
    {
      "source": "/api/category.php",
      "destination": "/api/api/category.php"
    },
    {
      "source": "/api/category/:category.json",
      "destination": "/api/api/category.php?category=:category"
    },
    {
      "source": "/api/:category.json",
      "destination": "/api/api/category.php?category=:category"
    },
    {
      "source": "/article/:slug",
      "destination": "/api/article.php?slug=:slug"
    },
    {
      "source": "/category/:category",
      "destination": "/api/category.php?category=:category"
    },
    {
      "source": "/search.php",
      "destination": "/api/search.php"
    },
    {
      "source": "/about.php",
      "destination": "/api/about.php"
    },
    {
      "source": "/contact.php",
      "destination": "/api/contact.php"
    },
    {
      "source": "/privacy.php",
      "destination": "/api/privacy.php"
    },
    {
      "source": "/rss.php",
      "destination": "/api/rss.php"
    },
    {
      "source": "/",
      "destination": "/api/index.php"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ],
  "crons": [
    {
      "path": "/api/agent-cron.php",
      "schedule": "*/30 * * * *"
    }
  ]
}
